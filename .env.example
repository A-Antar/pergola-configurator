# ── GoHighLevel CRM Integration ──────────────────────────
# Paste your GHL webhook URL here to receive leads automatically
# Get this from: GHL > Automation > Workflows > Create Workflow > Add Trigger > Webhook
VITE_GHL_WEBHOOK_URL="https://services.leadconnectorhq.com/hooks/your-webhook-id"
